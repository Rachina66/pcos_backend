generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  predictions  Prediction[]
  appointments Appointment[]
  cycleLogs    CycleLog[]   // ← add this
  symptomLogs  SymptomLog[]
  mealPlans    MealPlan[]
}

enum Role {
  USER
  ADMIN
  DOCTOR
}

model Prediction {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])

  // Patient inputs
  age              Float
  weight           Float
  height           Float
  bmi              Float
  bloodGroup       String
  cycleLengthDays  Float
  periodLengthDays Float
  regularOvulation Boolean
  fshLevel         Float
  lhLevel          Float
  androgenLevel    Float
  cystCount        Float
  hirsutism        Boolean
  fastingGlucose   Float
  activityLevel    Int
  stressLevel      Int
  pregnant         Boolean

  // ML Results
  prediction  Int
  probability Float
  riskLevel   String
  confidence  Float

  createdAt DateTime @default(now())

  @@index([userId])
}

model Doctor {
  id             String        @id @default(uuid())
  name           String
  specialization String
  qualification  String
  experience     Int
  hospital       String
  location       String
  phone          String
  email          String        @unique
  bio            String?
  imageUrl       String?
  availableDays  String[]
  timeSlots      String[]
  consultFee     Float
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  appointments   Appointment[]
}

model Appointment {
  id         String            @id @default(uuid())
  userId     String
  doctorId   String
  user       User              @relation(fields: [userId], references: [id])
  doctor     Doctor            @relation(fields: [doctorId], references: [id])
  date       DateTime
  timeSlot   String
  reason     String?
  reportFile String?
  status     AppointmentStatus @default(PENDING)
  notes      String?
  
  // ← ADD THESE 3 FIELDS
  consultationNotes String?
  prescription      String?
  diagnosis         String?
  
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([userId])
  @@index([doctorId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model EducationalContent {
  id          String          @id @default(uuid())
  title       String
  content     String
  category    ContentCategory
  imageUrl    String?
  tags        String[]
  isPublished Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum ContentCategory {
  PCOS_BASICS
  NUTRITION
  EXERCISE
  MENTAL_HEALTH
  TREATMENT
  LIFESTYLE
}


model CycleLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  startDate    DateTime
  endDate      DateTime?
  periodLength Int?
  symptoms     String[]
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model SymptomLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
  symptoms  String[]
  createdAt DateTime @default(now())

  @@index([userId])
}

model Meal {
  id           String       @id @default(uuid())
  name         String
  description  String
  whyItHelps   String
  ingredients  String[]
  recipe       String[]
  mealType     MealType
  riskCategory RiskCategory
  isVeg        Boolean      @default(false)
  calories     Int?
  carbs        Int?
  prepTime     String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  breakfastDays MealPlanDay[] @relation("Breakfast")
  lunchDays     MealPlanDay[] @relation("Lunch")
  dinnerDays    MealPlanDay[] @relation("Dinner")
  snackDays     MealPlanDay[] @relation("Snack")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum RiskCategory {
  HIGH_RISK
  LOW_RISK
  GENERAL
}


model MealPlan {
  id           String         @id @default(uuid())
  userId       String?        // null = template, has value = user's custom plan
  user         User?          @relation(fields: [userId], references: [id])
  riskCategory RiskCategory
  weekNumber   Int            @default(1)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  days         MealPlanDay[]

  @@index([userId])
}

model MealPlanDay {
  id          String   @id @default(uuid())
  mealPlanId  String
  mealPlan    MealPlan @relation(fields: [mealPlanId], references: [id])
  dayNumber   Int      // 1-7
  breakfastId String?
  lunchId     String?
  dinnerId    String?
  snackId     String?
  breakfast   Meal?    @relation("Breakfast", fields: [breakfastId], references: [id])
  lunch       Meal?    @relation("Lunch", fields: [lunchId], references: [id])
  dinner      Meal?    @relation("Dinner", fields: [dinnerId], references: [id])
  snack       Meal?    @relation("Snack", fields: [snackId], references: [id])

  @@index([mealPlanId])
}

